{
  "name": "gel-kiro-tapaas-trial-pack",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "description": "Active v0.3 Kiro trial build pack for TaPaaS transaction skeletons.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:all": "npm run build && npm run build:storybook",
    "build:report": "tsc && vite build --mode production 2>&1 | tail -5",
    "build:storybook": "storybook build -o dist/storybook",
    "lint": "eslint src/",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006"
  },
  "dependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "storybook": "^10.4.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14"
  }
}
