{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://service.nsw.gov.au/tapaas/track-2-spike/extracted-evidence.schema.json",
  "title": "Track 2 extracted evidence",
  "type": "object",
  "required": [
    "source",
    "summary",
    "selectedNode",
    "text",
    "instances",
    "unknowns",
    "reviewGates"
  ],
  "properties": {
    "source": {
      "type": "object",
      "required": ["fileKey", "nodeId", "extractedAt", "rawPath"],
      "properties": {
        "fileKey": { "type": "string" },
        "nodeId": { "type": "string" },
        "nodeIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "figmaUrl": { "type": "string" },
        "extractedAt": { "type": "string" },
        "rawPath": { "type": "string" }
      },
      "additionalProperties": false
    },
    "sourceNodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["nodeId", "nodeName", "nodeType", "sourceOrder", "text", "instances"],
        "properties": {
          "nodeId": { "type": "string" },
          "nodeName": { "type": "string" },
          "nodeType": { "type": "string" },
          "sourceOrder": { "type": "integer" },
          "descendantCount": { "type": "integer" },
          "selectedNode": { "type": "object" },
          "text": { "type": "array" },
          "instances": { "type": "array" },
          "likelyFields": { "type": "array" },
          "likelyCtas": { "type": "array" },
          "likelyValidationEvidence": { "type": "array" }
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "required": ["fileName", "nodeName", "nodeType", "descendantCount"],
      "properties": {
        "fileName": { "type": "string" },
        "nodeName": { "type": "string" },
        "nodeType": { "type": "string" },
        "descendantCount": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "selectedNode": { "type": "object" },
    "text": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "characters"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "characters": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "instances": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "componentId": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "unknowns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reviewGates": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
